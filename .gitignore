
## .gitignore

```gitignore
# Dependencies
node_modules/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files
.env
.env.local
.env.development
.env.production
.env.test

# Build output
dist/
build/
out/

# Cache
.cache/
.parcel-cache/
.vite/
.next/
.nuxt/

# Editor files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Temporary files
tmp/
temp/

# Coverage
coverage/

# Package manager
package-lock.json
yarn.lock
pnpm-lock.yaml